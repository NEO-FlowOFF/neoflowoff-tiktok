# Referencia: este modulo le por padrao o .env da raiz do repositorio.
# Se quiser isolar totalmente, copie este arquivo para apps/content-engine/.env
# e execute os scripts com --env-file apps/content-engine/.env

OPENAI_API_KEY="sk-..."
TAVILY_API_KEY="tvly-..."
OPENAI_MODEL="gpt-4o-mini"
NEO_GENERATE_IMAGE_IF_MISSING="1"
OPENAI_IMAGE_MODEL="gpt-image-1"
NEO_IMAGE_SIZE="1024x1536"
NEO_IMAGE_QUALITY="low"

NEO_MINE_MAX_RESULTS_PER_QUERY="5"
NEO_MINE_LIMIT_PRODUCTS="8"
NEO_RUN_MAX_PRODUCTS="2"

MINIO_ENDPOINT="http://localhost:9000"
MINIO_PUBLIC_BASE_URL="http://localhost:9000"
MINIO_ROOT_USER="minioadmin"
MINIO_ROOT_PASSWORD="minioadmin123"
MINIO_BUCKET="tiktok-assets"
