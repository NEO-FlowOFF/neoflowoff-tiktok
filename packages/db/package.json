{
  "name": "@neomello/db",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "db:generate": "prisma generate --config prisma.config.ts",
    "db:validate": "prisma validate --schema prisma/schema.prisma --config prisma.config.ts"
  },
  "dependencies": {
    "@prisma/client": "^7.4.2",
    "vite": "7.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "prisma": "^6.19.2",
    "typescript": "^5.9.3"
  }
}
