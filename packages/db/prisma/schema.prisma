generator client {
  provider   = "prisma-client-js"
  output     = "../generated/client"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum SocialAccountStatus {
  ACTIVE
  REFRESH_FAILED
  REVOKED
  SUSPENDED
}

enum CampaignStatus {
  QUEUED
  RENDERING
  IPFS_PINNED
  POSTING
  LIVE
  FAILED
}

model Workspace {
  id        String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  createdAt DateTime        @default(now())

  socialAccounts SocialAccount[]
  campaigns      Campaign[]
  orderSyncLogs  OrderSyncLog[]
}

model SocialAccount {
  id               String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId      String              @db.Uuid
  workspace        Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  provider         String
  providerId       String?
  shopId           String              @unique
  username         String?

  accessToken      String              @db.Text
  refreshToken     String              @db.Text
  tokenExpiresAt   DateTime
  refreshExpiresAt DateTime?

  status           SocialAccountStatus @default(ACTIVE)
  failureCount     Int                 @default(0)
  lastFailureAt    DateTime?
  lastRefreshedAt  DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  campaigns        Campaign[]
  webhookEvents    WebhookEventInbox[]

  // Real-time Dashboard Specifics
  creatorStats     CreatorStats?
  complianceAlerts ComplianceAlert[]
  orderSyncLogs    OrderSyncLog[]

  @@unique([provider, providerId])
  @@index([workspaceId, status])
  @@index([tokenExpiresAt, status])
  @@index([shopId, status])
}

model Campaign {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId    String         @db.Uuid
  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  socialAccountId String        @db.Uuid
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)

  productId      String

  ipfsCid        String?
  ipfsGatewayUrl String?        @db.Text

  providerJobId  String?
  status         CampaignStatus @default(QUEUED)
  lastError      String?        @db.Text
  publicUrl      String?        @db.Text

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([workspaceId, status])
  @@index([socialAccountId, status])
  @@index([providerJobId])
}

enum InboxStatus {
  PENDING
  PROCESSING
  DONE
  DEAD
}

model WebhookEventInbox {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  socialAccountId String         @db.Uuid
  socialAccount   SocialAccount  @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  externalEventId String         @unique
  eventType       String
  rawPayload      Json
  receivedAt      DateTime       @default(now())
  processedAt     DateTime?
  status          InboxStatus    @default(PENDING)
  retryCount      Int            @default(0)
  lastError       String?        @db.Text

  @@index([status, receivedAt])
  @@index([socialAccountId, status])
}

model CreatorStats {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  socialAccountId  String        @unique @db.Uuid
  socialAccount    SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)

  // Ranking & Monitor Metrics
  totalPosts       Int           @default(0)
  totalViews       Int           @default(0)
  totalSalesVolume Decimal       @default(0) @db.Decimal(15, 2)
  performanceScore Float         @default(0.0)

  // Agency (Health/Compliance)
  activeAlerts     Int           @default(0)
  lastSyncAt       DateTime      @default(now())

  updatedAt        DateTime      @updatedAt
}

model OrderSyncLog {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId     String         @db.Uuid
  workspace       Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  socialAccountId String?        @db.Uuid
  socialAccount   SocialAccount? @relation(fields: [socialAccountId], references: [id], onDelete: SetNull)

  orderId         String         @unique
  status          String
  gmv             Decimal        @default(0) @db.Decimal(15, 2)
  currency        String         @default("BRL")

  purchasedAt     DateTime
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([workspaceId, status])
  @@index([socialAccountId, status])
}

model ComplianceAlert {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  socialAccountId String        @db.Uuid
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)

  type            String        // Ex: "DEAUTHORIZED", "SHADOWBAN", "VIDEO_REJECTED"
  severity        String        // Ex: "HIGH", "MEDIUM", "LOW"
  message         String        @db.Text
  isResolved      Boolean       @default(false)

  createdAt       DateTime      @default(now())
  resolvedAt      DateTime?

  @@index([socialAccountId, isResolved])
}
