# Shared Core
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"
REDIS_URL="redis://default:PASSWORD@HOST:PORT"
TOKEN_ENCRYPTION_KEY="PUT_32_BYTE_HEX_KEY_HERE"
OPENAI_API_KEY="sk-..."

# API Service
PORT="3000"
DB_CONNECT_TIMEOUT_MS="10000"
API_BASE_URL="https://neo-tiktok-api.up.railway.app"
TIKTOK_SHOP_APP_KEY="PUT_TIKTOK_SHOP_APP_KEY_HERE"
TIKTOK_SHOP_APP_SECRET="PUT_TIKTOK_SHOP_APP_SECRET_HERE"
TIKTOK_SHOP_AUTHORIZE_URL="https://services.tiktokshop.com/open/authorize"
TIKTOK_SHOP_TOKEN_URL="https://open-api.tiktokglobalshop.com/api/v2/token/refresh"
TIKTOK_SHOP_REDIRECT_URI="https://neo-tiktok-api.up.railway.app/oauth/tiktok-shop/callback"
OAUTH_STATE_SECRET="PUT_LONG_RANDOM_SECRET_HERE_MIN_16"
TIKTOK_WEBHOOK_SECRET="SAME_AS_APP_SECRET"
TIKTOK_WEBHOOK_SIGNATURE_HEADER="x-tiktok-signature"
TIKTOK_WEBHOOK_TIMESTAMP_HEADER="x-tiktok-timestamp"

# Worker Service
TIKTOK_SHOP_API_BASE_URL="https://open-api.tiktokglobalshop.com"
TIKTOK_SHOP_AUTH_REVOKED_EVENT="AUTHORIZATION_REVOKED"
TIKTOK_SHOP_INVENTORY_UPDATE_PATH="/product/inventory/update"

# Dashboard Service
VITE_API_BASE_URL="https://neo-tiktok-api.up.railway.app"
